APP_NAME=Millennium
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=millennium
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Solo entorno local (demo / video / equipo) ---
# Una contraseña para todos los usuarios del LocalLoginCredentialsSeeder. Si está vacío, el seeder usa las claves por defecto definidas en código (cambialas o usá esta variable para no dejar secretos en el repo).
# Nunca subas .env con valores reales a un repositorio público.
# MILLENNIUM_LOCAL_DEMO_PASSWORD=

# Primer número correlativo de factura (solo numérico en BD). Si ya hay facturas, sigue en max+1.
# MILLENNIUM_FACTURA_NUMERO_INICIAL=100000

# Filtro "Zona (contiene)" en /reportes: valor inicial si la URL no incluye ?zona= (ej. región habitual de ventas).
# MILLENNIUM_REPORTE_ZONA_DEFAULT=

# Zonas comerciales / rutas fijas para clientes (separadas por coma). Si queda vacío se usan valores por defecto en código.
# MILLENNIUM_ZONAS_COMERCIALES=Portuguesa,Amazonas,Aragua,Barinas

# Cabecera en PDFs (nota de entrega, movimientos de pago, etc.). Ajustá en producción al RIF y razón social reales.
# MILLENNIUM_EMPRESA_NOMBRE_CORTO=INCAPOR
# MILLENNIUM_EMPRESA_RAZON="INDUSTRIAS CARNICAS PORTUGUESA, C.A."
# MILLENNIUM_EMPRESA_RIF=J-40101298-1
