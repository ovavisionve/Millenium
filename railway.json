{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "sh scripts/railway-build.sh"
  },
  "deploy": {
    "preDeployCommand": [
      "php artisan migrate --force --no-interaction"
    ],
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
